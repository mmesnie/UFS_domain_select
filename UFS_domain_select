#!/bin/bash

set -e

export UFS_DOMAIN_SELECT_HOME=`echo $(realpath $(dirname $0))`

echo "Initializing conda..."
eval "$(${UFS_DOMAIN_SELECT_HOME}/build/anaconda3/bin/conda shell.bash hook)"

echo "Activating regional_workflow-2.2.0..."
conda activate regional_workflow-2.2.0

echo "Launching GUI..."
${UFS_DOMAIN_SELECT_HOME}/UFS_domain_select.py
