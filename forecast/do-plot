#!/bin/bash

if [ $# != 2 ]; then
        echo "usage: $0 <hpc|spack|zee> <2.2.0|3.0.0>"
        exit 1
fi

if [ ! $1 == "hpc" ] && [ ! $1 == "spack" ] && [ ! $1 == "zee" ]; then
        echo \"$1\" is an invalid stack
        echo "usage: $0 <hpc|spack|zee> <2.2.0|3.0.0>"
        exit 1
fi

if [ "$2" == "2.2.0" ]; then
        STACK=$1
        VER=$2
elif [ "$2" == "3.0.0" ]; then
        echo "$1 not yet implemented"
        exit 1
else
        echo "$2 not supported"
        exit 1
fi

export UFS_DOMAIN_SELECT_HOME=$(realpath $(dirname $0))/..

eval "$(${UFS_DOMAIN_SELECT_HOME}/build/anaconda3/bin/conda shell.bash hook)"

conda activate regional_workflow-$VER || exit 1

cd ${UFS_DOMAIN_SELECT_HOME}/build/expt_dirs/test_$STACK/*/postprd/

rm -f *.png

for i in `ls PRSLEV*`; do
	cmd="$UFS_DOMAIN_SELECT_HOME/UFS_domain_select.py -f $i -x";
	echo $cmd
	$cmd || exit 1
done

ristretto *.png &
