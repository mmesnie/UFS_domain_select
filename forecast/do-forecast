#!/bin/bash

if [ $# != 2 ]; then
        echo "usage: $0 <hpc|spack|zee> <2.2.0|3.0.0>"
        exit 1
fi

if [ ! $1 == "hpc" ] && [ ! $1 == "spack" ] && [ ! $1 == "zee" ]; then
	echo \"$1\" is an invalid stack
        echo "usage: $0 <hpc|spack|zee> <2.2.0|3.0.0>"
	exit 1 
fi

if [ "$2" == "2.2.0" ]; then
	STACK=$1
	VER=$2
elif [ "$2" == "3.0.0" ]; then
        echo "$1 not yet implemented"
        exit 1
else
        echo "$2 not supported"
        exit 1
fi

#
# Be careful here. The setting of EXPT_SUBDIR leads to strange
# errors in run_make_orog.sh, particularly if the path length
# is too long.
#
export UFS_DOMAIN_SELECT_HOME=`echo $(realpath $(dirname $0))/.. | sed 's/\/forecast\/\.\.//'`
EXPT_BASEDIR=$UFS_DOMAIN_SELECT_HOME/build/expt
EXPT_SUBDIR=test_${STACK}

echo "Experiment path is $EXPT_BASEDIR/$EXPT_SUBDIR"
length=`echo $EXPT_BASEDIR/$EXPT_SUBDIR | wc -c`
#echo "length is $length"
sleep 1

if [ $length -gt 63 ]; then
	echo
	echo "Bad experiment directory path: \"$EXPT_BASEDIR/$EXPT_SUBDIR\""
	echo "Path length is $length"
	echo "Path length cannot exceed 63 bytes"
	exit 1
fi

EXTRN_MDL_SOURCE_BASEDIR_ICS=$UFS_DOMAIN_SELECT_HOME/build/DATA-2.2.0/input_model_data/FV3GFS/grib2/2019061518
EXTRN_MDL_SOURCE_BASEDIR_LBCS=$UFS_DOMAIN_SELECT_HOME/build/DATA-2.2.0/input_model_data/FV3GFS/grib2/2019061518

export EXPTDIR=$EXPT_BASEDIR/$EXPT_SUBDIR

#
# Apply patches to UFS
#

cd ${UFS_DOMAIN_SELECT_HOME}/forecast || exit 1

cores=`lscpu -p | egrep -v '^#' | wc -l`
layout=`echo "sqrt($cores - 1)" | bc`

cat config.yaml.tmpl | sed "s|<EXPT_SUBDIR>|${EXPT_SUBDIR}|g" | sed "s|<EXPT_BASEDIR>|${EXPT_BASEDIR}|g" | sed "s|<EXTRN_MDL_SOURCE_BASEDIR_ICS>|${EXTRN_MDL_SOURCE_BASEDIR_ICS}|g" | sed "s|<EXTRN_MDL_SOURCE_BASEDIR_LBCS>|${EXTRN_MDL_SOURCE_BASEDIR_LBCS}|g" | sed "s|<LAYOUT_X>|${layout}|g" | sed "s|<LAYOUT_Y>|${layout}|g" > ${UFS_DOMAIN_SELECT_HOME}/build/ufs-srweather-app-$VER-with-$STACK-stack/ush/config.yaml || exit 1 

cat linux-$VER.yaml.tmpl | sed "s|<UFS_DOMAIN_SELECT_HOME>|${UFS_DOMAIN_SELECT_HOME}|g" > ${UFS_DOMAIN_SELECT_HOME}/build/ufs-srweather-app-$VER-with-$STACK-stack/ush/machine/linux.yaml || exit 1

#
# Activate spack environment, if needed
#

if [ $STACK == "spack" ] || [ $STACK == "zee" ]; then
	source $UFS_DOMAIN_SELECT_HOME/build/$STACK-stack-for-$VER/share/spack/setup-env.sh || exit 1
	if [ $STACK == "spack" ]; then
		ENV="ufs"
	elif [ $STACK == "zee" ]; then
		ENV="zee"
	fi
	echo "### $0: activating $ENV spack environment"
	spack env activate $ENV -p || exit 1
        export LD_LIBRARY_PATH="`spack location -i jasper`/lib:$LD_LIBRARY_PATH"
        export LD_LIBRARY_PATH="`spack location -i netcdf-c`/lib:$LD_LIBRARY_PATH"
        export LD_LIBRARY_PATH="`spack location -i netcdf-fortran`/lib:$LD_LIBRARY_PATH"
        export LD_LIBRARY_PATH="`spack location -i parallelio`/lib:$LD_LIBRARY_PATH"
fi

#
# Activate conda environment
#

eval "$(${UFS_DOMAIN_SELECT_HOME}/build/anaconda3/bin/conda shell.bash hook)" || exit 1
conda activate regional_workflow-$VER || exit 1
export PYTHONPATH="$PYTHONPATH:$UFS_DOMAIN_SELECT_HOME/build/ufs-srweather-app-2.2.0-with-$STACK-stack/ush/python_utils/workflow-tools/"
export PYTHONPATH="$PYTHONPATH:$UFS_DOMAIN_SELECT_HOME/build/ufs-srweather-app-2.2.0-with-$STACK-stack/ush/python_utils/workflow-tools/src"

cd ${UFS_DOMAIN_SELECT_HOME}/build/ufs-srweather-app-$VER-with-$STACK-stack/ush || exit 1
./generate_FV3LAM_wflow.py || exit 1

cd $EXPTDIR || exit 1
cp ${UFS_DOMAIN_SELECT_HOME}/build/ufs-srweather-app-$VER-with-$STACK-stack/ush/wrappers/* . || exit 1

./run_make_grid.sh || exit 1
./run_get_ics.sh || exit 1
./run_get_lbcs.sh || exit 1
./run_make_orog.sh || exit 1
./run_make_sfc_climo.sh || exit 1
./run_make_ics.sh || exit 1
./run_make_lbcs.sh || exit 1
./run_fcst.sh || exit 1
./run_post.sh || exit 1
